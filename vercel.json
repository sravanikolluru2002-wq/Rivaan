{
  "buildCommand": "cd frontend && yarn install --frozen-lockfile && yarn export:web",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && yarn install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!api|assets|icons|manifest.json|service-worker.js|favicon.ico|splash.png).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    }
  ]
}
